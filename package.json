{
  "name": "telegram-cloud-mirror-bot",
  "version": "2.0.0",
  "description": "Telegram bot for cloud-to-cloud file mirroring with aria2c and Rclone",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "worker": "node dist/workers/mirror.worker.js",
    "dev:worker": "tsx watch src/workers/mirror.worker.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["telegram", "bot", "mirror", "cloud", "aria2c", "rclone"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "grammy": "^1.38.0",
    "@grammyjs/conversations": "^1.2.0",
    "@grammyjs/throttler": "^1.2.0",
    "bullmq": "^5.28.0",
    "ioredis": "^5.4.1",
    "better-sqlite3": "^11.0.0",
    "zod": "^3.24.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "opossum": "^8.1.0",
    "uuid": "^11.0.0",
    "ws": "^8.18.0",
    "axios": "^1.7.9",
    "express": "^4.21.0",
    "prom-client": "^16.0.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.0",
    "@types/express": "^4.17.21",
    "eslint": "^9.17.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "typescript-eslint": "^8.18.0",
    "prettier": "^3.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
