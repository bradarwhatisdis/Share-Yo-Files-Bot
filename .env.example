# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
WEBHOOK_URL=https://your-domain.com/telegram-webhook
WEBHOOK_SECRET=your_webhook_secret

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Aria2c Configuration
ARIA2C_RPC_URL=ws://localhost:6800/jsonrpc
ARIA2C_RPC_SECRET=your_aria2c_secret
ARIA2C_MAX_CONCURRENT=5
ARIA2C_SPLIT=16
ARIA2C_MIN_SPLIT_SIZE=10M

# Rclone Configuration
RCLONE_RC_URL=http://localhost:5572
RCLONE_RC_USER=admin
RCLONE_RC_PASS=admin

# Database Configuration
DB_PATH=./data/mirrorbot.db

# Application Configuration
NODE_ENV=development
LOG_LEVEL=info
PORT=3000

# Queue Configuration
QUEUE_MAX_JOBS=1000
QUEUE_REMOVE_ON_COMPLETE=100
QUEUE_REMOVE_ON_FAIL=50

# User Quotas (in bytes)
DEFAULT_USER_QUOTA_DAILY=10737418240
PREMIUM_USER_QUOTA_DAILY=1099511627776

# Rate Limiting (requests per hour)
RATE_LIMIT_FREE=5
RATE_LIMIT_PREMIUM=50
RATE_LIMIT_ADMIN=0
